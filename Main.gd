func _today_str() -> String:
	var d := Time.get_date_dict_from_system()
	return "%04d-%02d-%02d" % [d.year, d.month, d.day]

func _bigday_reseed(salt: int) -> void:
	if bigday:
		seed(bigday_seed + salt)
