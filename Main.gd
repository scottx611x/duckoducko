	# fade overlay: every scene switch fades in from black (added LAST = atop the HUD)
	fade_rect = ColorRect.new()
	fade_rect.color = Color(0, 0, 0, 0)
	fade_rect.size = VIEW
	fade_rect.mouse_filter = Control.MOUSE_FILTER_IGNORE
