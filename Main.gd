	state = St.GROUNDED
	hop_t = 0.0
	mega_t = 0.0
	laser_t = 0.0
	duck_x = VIEW.x * 0.5
	target_x = duck_x
	last_duck_x = duck_x
	duck_vx = 0.0
	duck_shake = 0.0
	speed = BASE_SPEED
	distance = 0.0
	alive = true
	dead_msg = ""
	loft = 0.0
	loft_ready = false
